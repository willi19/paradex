<?xml version="1.0" ?>
<!--Made by Jaesung Lee from PRIME Lab/ Last update: 2025-08-15-->

<robot name="kistar_hand">

  <!-- MOUNT -->
    <link name="mount">
      <collision>
        <geometry>
          <mesh filename="meshes/kistar/mount.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.0"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="meshes/kistar/mount.STL"/>
        </geometry>
        <material name="Grey">
          <color rgba="0.2 0.2 0.2 1"/>
        </material>
      </visual>
    </link>

  <!-- PALM -->
    <link name="palm">
      <collision>
        <geometry>
          <mesh filename="meshes/kistar/Palm.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.15476"/>
        <origin rpy="0 0 0" xyz="-0.01669 0.00079 -0.02862"/>
        <inertia ixx="0.00032705182" ixy="-0.00001050022" ixz="0.00005386046"
        iyy="0.00035100257" iyz="-0.00000337009" izz="0.00016323150"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="meshes/kistar/Palm.STL"/>
        </geometry>
        <material name="Black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
    </link>

  <!-- MOUNT JOINT -->
    <joint name="kistar_mount_joint" type="fixed">
      <origin rpy="0. 0. 0." xyz="0. 0. 0.071"/>
      <parent link="mount"/>
      <child link="palm"/>
    </joint>


